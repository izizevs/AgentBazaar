# AgentBazaar — environment template
# Copy to .env and fill in values. .env is gitignored.

# GitHub (required for PR/issue automation)
# Create: https://github.com/settings/tokens (classic) with `repo` + `workflow` scopes
GITHUB_TOKEN=

# Solana / Helius (required for indexer and RPC)
# Create API key: https://dev.helius.xyz/
HELIUS_API_KEY=
# Webhook auth: set this value in the Helius dashboard webhook `authHeader` field.
# Helius sends it verbatim as the Authorization header on every delivery.
# Generate with: openssl rand -base64 48 | tr -d '\n' | sed 's/^/Bearer /'
HELIUS_WEBHOOK_SECRET=
# Webhook ID created via Helius API — used to update the URL when deploying.
# See apps/indexer/docs/helius-setup.md for management commands.
HELIUS_WEBHOOK_ID=
# Pinata IPFS gateway for metadata fetches (optional).
# Use your dedicated gateway for better rate limits in production.
# Format: https://your-subdomain.mypinata.cloud/ipfs
PINATA_GATEWAY=
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# IPFS pinning (required for metadata uploads from SDK)
# Create JWT: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=

# Database
# Inside devcontainer: injected by docker-compose.yml (hostname `postgres`)
# Outside devcontainer: point at your local/remote Postgres
DATABASE_URL=postgres://agentbazaar:agentbazaar@postgres:5432/agentbazaar

# Program IDs — re-deployed to devnet as of M1 milestone (all 4 program keypairs refreshed)
BAZAAR_REGISTRY_PROGRAM_ID=ADWoSmfUWLLRGMWZ61xuAMPhDgG77ziqAC5MA9voqLn3
BAZAAR_ESCROW_PROGRAM_ID=EhFptDs4mz6rt7HDmt8pB7ZogiqxUMVhpjB3NvToXxW2
BAZAAR_SLA_PROGRAM_ID=26rhkrBkf75ijDoDuhed8m94FkuhB2MukvqtWYEDegd8
BAZAAR_EVALUATOR_PROGRAM_ID=BxctnHyx9UJT7XobxHK3X548sSoPQB96Ca2fMEzYYMS8

# SATI (identity / reputation layer)
SATI_PROGRAM_ID=

# x402 (Coinbase hosted facilitator default)
X402_FACILITATOR_URL=https://facilitator.x402.coinbase.com
