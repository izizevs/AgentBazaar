{
  "name": "agentbazaar",
  "version": "0.0.0",
  "private": true,
  "description": "On-chain agent-to-agent marketplace on Solana with SLA-enforced escrow and reputation scoring.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "build:programs": "cd programs && anchor build",
    "test:programs": "cd programs && anchor test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
