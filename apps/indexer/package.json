{
  "name": "@agentbazaar/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:integration": "INTEGRATION=true vitest run tests/listing-upsert.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@agentbazaar/idl": "workspace:*",
    "@coral-xyz/anchor": "0.31.1",
    "@hono/node-server": "^1.13.7",
    "dotenv-mono": "^1.4.0",
    "drizzle-orm": "^0.41.0",
    "helius-sdk": "^1.3.9",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.2",
    "typescript": "5.4.3",
    "vitest": "^2.0.0"
  }
}
