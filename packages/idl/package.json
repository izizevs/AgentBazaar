{
  "name": "@agentbazaar/idl",
  "version": "0.1.0",
  "private": true,
  "description": "Anchor IDL JSON + TypeScript types for AgentBazaar on-chain programs.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./generated": {
      "types": "./src/generated/index.ts",
      "import": "./src/generated/index.ts"
    },
    "./bazaar-registry.json": "./idl/bazaar_registry.json"
  },
  "files": [
    "idl",
    "scripts",
    "src"
  ],
  "scripts": {
    "sync": "cp ../../programs/target/idl/bazaar_registry.json ./idl/bazaar_registry.json && cp ../../programs/target/types/bazaar_registry.ts ./src/bazaar-registry.ts",
    "codegen": "node scripts/codegen.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "5.4.3",
    "vitest": "^2.0.0"
  }
}
